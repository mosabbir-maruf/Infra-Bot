# Mosabbir Infrastructure Bot - Environment Variables Example
# Duplicate this file to '.dev.vars' for local development or upload secrets to Cloudflare using:
# npx wrangler secret put <SECRET_NAME>

# 1. Telegram Configurations
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"
AUTHORIZED_USER_IDS="123456789,987654321"
# Optional secret token to authenticate webhook requests from Telegram Bot API
TELEGRAM_WEBHOOK_SECRET="a_secure_arbitrary_webhook_secret_token"

# 2. Cloud Provider Credentials
# AWS EC2 Credentials (IAM User restricted to target instances ARNs)
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_REGION="us-east-1"

# DigitalOcean Credentials (Read/Write Personal Access Token)
DIGITALOCEAN_TOKEN="dop_v1_abcdef1234567890abcdef1234567890"

# 3. Server Registry Config (JSON string mapping aliases to provider configurations)
SERVERS_CONFIG='{
  "ai-gateway-prod": {
    "provider": "aws",
    "region": "ap-south-1",
    "instanceId": "i-0123456789abcdef0"
  },
  "docs-server": {
    "provider": "digitalocean",
    "dropletId": "123456789"
  }
}'

# 4. Telemetry Monitoring Security (HMAC shared secret key)
MONITORING_SECRET="a_secure_shared_hmac_secret_key_generate_using_openssl_rand"

# 5. Environment
NODE_ENV="development"

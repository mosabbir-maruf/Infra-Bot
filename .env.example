# Infrastructure Bot - Environment Variables Example
# Duplicate this file to '.dev.vars' for local development or upload secrets to Cloudflare using:
# npx wrangler secret put <SECRET_NAME>

# 1. Telegram Configurations
TELEGRAM_BOT_TOKEN="123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ"
AUTHORIZED_USER_IDS="123456789,987654321"
# Optional secret token to authenticate webhook requests from Telegram Bot API
TELEGRAM_WEBHOOK_SECRET="a_secure_arbitrary_webhook_secret_token"

# 2. Cloud Provider Credentials
# AWS EC2 Credentials (IAM User restricted to target instances ARNs)
AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
AWS_REGION="us-east-1"

# DigitalOcean Credentials (Personal Access Token with droplet:read + droplet:update custom scopes; see docs/providers/digitalocean.md)
DIGITALOCEAN_TOKEN="dop_v1_abcdef1234567890abcdef1234567890"

# Azure Credentials (Service Principal with VM contributor role)
AZURE_TENANT_ID="00000000-0000-0000-0000-000000000000"
AZURE_CLIENT_ID="00000000-0000-0000-0000-000000000001"
# AZURE_CLIENT_SECRET is the Secret Value (long random string), NOT the Secret ID (UUID).
# Found in: App registration → Certificates & secrets → copy "Value" column.
AZURE_CLIENT_SECRET="q8n~abcDEF0123456789_long_random_secret_value_generated_by_azure"
AZURE_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000002"
AZURE_REGION="eastus"

# 3. Server Registry Config (JSON string mapping aliases to provider configurations)
SERVERS_CONFIG='{
  "ai-gateway-prod": {
    "provider": "aws",
    "region": "ap-south-1",
    "instanceId": "i-0123456789abcdef0"
  },
  "docs-server": {
    "provider": "digitalocean",
    "dropletId": "123456789"
  },
  "Mosabbir-Cloud": {
    "provider": "azure",
    "region": "eastasia",
    "resourceGroup": "Mosabbir-Cloud_group",
    "vmName": "Mosabbir-Cloud"
  }
}'

# 4. Telemetry Monitoring Security (HMAC shared secret key)
MONITORING_SECRET="a_secure_shared_hmac_secret_key_generate_using_openssl_rand"

# 5. Environment
NODE_ENV="development"
